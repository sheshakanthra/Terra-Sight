# TerraSight environment template.
# Copy to apps/api/.env and apps/web/.env.local, then fill in real values.
# Never commit filled-in copies.
#
# Those two paths are the only ones read. A .env in the repo root is ignored by
# both apps: Next.js loads env files from apps/web, and the API anchors its env
# file to apps/api regardless of the directory it is launched from.
#
# Save these files as UTF-8 *without* a BOM. A BOM would be folded into the
# first variable name and that setting would be dropped. The API tolerates one
# (utf-8-sig); Next.js does not.

# ---------------------------------------------------------------------------
# apps/api  (FastAPI)
# ---------------------------------------------------------------------------
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Browser origin allowed through CORS.
WEB_ORIGIN=http://localhost:3000

# Supabase project (Settings -> API). Service-role key is server-only: it
# bypasses RLS and must never reach the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Groq inference (https://console.groq.com/keys). Optional: advice falls back
# to deterministic templates when absent.
GROQ_API_KEY=

# Shared secret guarding the daily refresh-all cron endpoint. Required only in
# production. Any long random string; set the SAME value on the Render API
# service and in the repo's GitHub Actions secrets (the daily workflow sends it
# as the X-Cron-Secret header).
CRON_SECRET=

# In production, WEB_ORIGIN must be the deployed web origin (e.g.
# https://terrasight.vercel.app), or the browser is blocked by CORS.

# ---------------------------------------------------------------------------
# apps/web  (Next.js) — NEXT_PUBLIC_* values are exposed to the browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
