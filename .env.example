# TerraSight environment template.
# Copy to apps/api/.env and apps/web/.env.local, then fill in real values.
# Never commit filled-in copies.

# ---------------------------------------------------------------------------
# apps/api  (FastAPI)
# ---------------------------------------------------------------------------
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Browser origin allowed through CORS.
WEB_ORIGIN=http://localhost:3000

# Supabase project (Settings -> API). Service-role key is server-only: it
# bypasses RLS and must never reach the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Groq inference (https://console.groq.com/keys). Optional: advice falls back
# to deterministic templates when absent.
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# apps/web  (Next.js) — NEXT_PUBLIC_* values are exposed to the browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
